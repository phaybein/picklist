{
    "name": "phaybein/picklist",
    "description": "CLI that turns a YouTube playlist into a ranked weekly watch queue and publishes it to Obsidian.",
    "keywords": ["youtube", "obsidian", "laravel zero", "console", "cli", "playlist", "automation", "productivity"],
    "homepage": "https://github.com/phaybein/picklist",
    "type": "project",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/phaybein/picklist/issues",
        "source": "https://github.com/phaybein/picklist"
    },
    "authors": [
        {
            "name": "Mauro Martinez"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel-zero/framework": "^12.0.2"
    },
    "require-dev": {
        "laravel/pint": "^1.25.1",
        "mockery/mockery": "^1.6.12",
        "pestphp/pest": "^3.8.4|^4.1.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": ["picklist"],
    "scripts": {
        "test": "./vendor/bin/pest",
        "lint": "./vendor/bin/pint"
    }
}
